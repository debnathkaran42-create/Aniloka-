# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

NODE_ENV=development
PORT=4000

# Long random string — generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Your deployed frontend URL(s), comma-separated. Use * only for local testing.
CORS_ORIGIN=*

# First admin account, auto-created on first boot if no admin exists yet.
ADMIN_EMAIL=aniloka@admin.com
ADMIN_PASSWORD=KarnaTejas67

# Your real UPI ID (VPA) that payments should be sent to, e.g. yourname@okhdfcbank
UPI_VPA=yourupi@bank
UPI_PAYEE_NAME=AniLoka

# Rate limiting (general API)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
